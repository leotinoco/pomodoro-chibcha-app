# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# IDEs
.idea/
.vscode/

# typescript
*.tsbuildinfo
next-env.d.ts

# build caches
.turbo/
.swc/
.cache/

# other dependencies
vendor/

# agents and security
/.agents
